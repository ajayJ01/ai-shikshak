# ─────────────────────────────────────────────
#  AI Shikshak — Environment Configuration
#  Copy this file: cp .env.example .env
#  Then fill in your values below
# ─────────────────────────────────────────────

# ── Groq API Key (required)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Groq Models (optional — defaults shown)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VIS_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Ollama Local AI (optional — for offline fallback)
# Install Ollama from: https://ollama.ai
# Then run: ollama pull qwen2.5:7b
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
